{
	"collections": [
		{
			"name": "events",
			"schema": {
				"bsonType": "object",
				"required": ["title", "dateTime", "category"],
				"properties": {
					"title": { "bsonType": "string", "label": "活动标题" },
					"category": { "bsonType": "string", "label": "活动类型", "enum": ["school", "ptsa"] },
					"description": { "bsonType": "string", "label": "活动描述" },
					"imageUrl": { "bsonType": "string", "label": "海报图片" },
					"dateTime": { "bsonType": "timestamp", "label": "活动时间" },
					"location": { "bsonType": "string", "label": "活动地点" },
					"schoolId": { "bsonType": "string", "label": "学校ID" },
					"section": { "bsonType": "string", "label": "学部" },
					"grade": { "bsonType": "array", "label": "适用年级" },
					"remindBefore": { "bsonType": "int", "label": "提前提醒" },
					"createdBy": { "bsonType": "string", "label": "创建者" },
					"createdAt": { "bsonType": "timestamp", "label": "创建时间" }
				}
			}
		},
		{
			"name": "schools",
			"schema": {
				"bsonType": "object",
				"properties": {
					"name": { "bsonType": "string", "label": "学校名称" },
					"code": { "bsonType": "string", "label": "学校代码" }
				}
			}
		},
		{
			"name": "sections",
			"schema": {
				"bsonType": "object",
				"properties": {
					"schoolId": { "bsonType": "string", "label": "学校ID" },
					"name": { "bsonType": "string", "label": "学部名称", "enum": ["小学部", "初中部", "高中部"] },
					"grades": { "bsonType": "array", "label": "年级列表" }
				}
			}
		},
		{
			"name": "invite_codes",
			"schema": {
				"bsonType": "object",
				"required": ["code", "schoolId", "section", "grade", "className"],
				"properties": {
					"code": { "bsonType": "string", "label": "邀请码" },
					"schoolId": { "bsonType": "string", "label": "学校ID" },
					"section": { "bsonType": "string", "label": "学部" },
					"grade": { "bsonType": "string", "label": "年级" },
					"className": { "bsonType": "string", "label": "班级" },
					"status": { "bsonType": "string", "label": "状态", "enum": ["pending", "active", "used"] },
					"userId": { "bsonType": "string", "label": "使用者ID" },
					"usedAt": { "bsonType": "timestamp", "label": "使用时间" },
					"createdAt": { "bsonType": "timestamp", "label": "创建时间" }
				}
			}
		},
		{
			"name": "join_requests",
			"schema": {
				"bsonType": "object",
				"required": ["userId", "schoolId", "section", "grade", "className"],
				"properties": {
					"userId": { "bsonType": "string", "label": "用户ID" },
					"schoolId": { "bsonType": "string", "label": "学校ID" },
					"section": { "bsonType": "string", "label": "学部" },
					"grade": { "bsonType": "string", "label": "年级" },
					"className": { "bsonType": "string", "label": "班级" },
					"status": { "bsonType": "string", "label": "状态", "enum": ["pending", "approved", "rejected"] },
					"createAt": { "bsonType": "timestamp", "label": "申请时间" }
				}
			}
		},
		{
			"name": "reminders",
			"schema": {
				"bsonType": "object",
				"properties": {
					"eventId": { "bsonType": "string", "label": "活动ID" },
					"userId": { "bsonType": "string", "label": "用户ID" },
					"remindTime": { "bsonType": "timestamp", "label": "提醒时间" }
				}
			}
		},
		{
			"name": "users",
			"schema": {
				"bsonType": "object",
				"properties": {
					"openid": { "bsonType": "string", "label": "微信OpenID" },
					"nickname": { "bsonType": "string", "label": "昵称" },
					"avatar": { "bsonType": "string", "label": "头像" },
					"role": { "bsonType": "string", "label": "角色", "enum": ["super_admin", "section_admin", "grade_admin", "parent"] },
					"schoolId": { "bsonType": "string", "label": "学校ID" },
					"section": { "bsonType": "string", "label": "学部" },
					"grades": { "bsonType": "array", "label": "年级班级" },
					"subscribe": { "bsonType": "bool", "label": "是否订阅通知" },
					"createAt": { "bsonType": "timestamp", "label": "注册时间" }
				}
			}
		}
	]
}
